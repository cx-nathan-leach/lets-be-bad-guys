                    "https://github.com/django/django/commit/ed682a24fca774818542757651bfba576c3fc3ef"
                  ]
                }
              },
              "helpUri": "https://nvd.nist.gov/vuln/detail/CVE-2019-14234",
              "shortDescription": {
                "text": "CVE-2019-14234"
              }
