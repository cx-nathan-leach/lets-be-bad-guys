                    "https://github.com/django/django/commit/3394fc6132436eca89e997083bae9985fb7e761e"
                  ]
                }
              },
              "helpUri": "https://nvd.nist.gov/vuln/detail/CVE-2024-27351",
              "shortDescription": {
                "text": "CVE-2024-27351"
              }
